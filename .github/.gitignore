# Dependencies
node_modules/
yarn.lock
package-lock.json      # Keep this un-ignored in your root, but ignore it if generated inside sub-folders

# Environment variables
.env
.env.local
.env.*.local

# Build & Validator Outputs
dist/
build/
*.js.map
validation-result.json  # Crucial: Blocks local test logs from spilling into the repo
result.json             # Blocks root-level local pipeline test files

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS Metadata
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Temporary files & Pipeline Workspaces
.tmp/
temp/
/tmp/                   # Prevents local emulation from caching execution files
