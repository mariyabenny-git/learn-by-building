{
  "name": "learn-by-building-validator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Validator scripts for Learn by Building platform",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "validate:local": "node index.js --path ./test-recipe.json --output ./result.json",
    "validate:remote": "node index.js --path https://api.example.com/quiz.json --output ./remote-result.json"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
